@page "/repositories/{RepositoryId:guid}"
@inject IConductorReadModelQueries Queries

<PageTitle>Repository - Conductor</PageTitle>

<section class="dashboard">
    @if (Repository is null)
    {
        <section class="empty-state">
            <p>Repository not found.</p>
        </section>
    }
    else
    {
        <header class="dashboard-header">
            <div>
                <p class="eyebrow">Repository command centre</p>
                <h1>@Repository.FullName</h1>
            </div>
            <span class="@HealthStatusClass(Repository.HealthStatus)">@DisplayHealth(Repository.HealthStatus)</span>
        </header>

        <section class="detail-grid">
            <article class="detail-panel">
                <span>Project</span>
                <strong>@Repository.ProjectName</strong>
            </article>
            <article class="detail-panel">
                <span>Default branch</span>
                <strong>@Repository.DefaultBranch</strong>
            </article>
            <article class="detail-panel">
                <span>Execution mode</span>
                <strong>@DisplayMode(Repository.ExecutionMode)</strong>
            </article>
            <article class="detail-panel">
                <span>Last seen</span>
                <strong>@FormatLastSeen(Repository.LastSeenAtUtc)</strong>
            </article>
        </section>

        <section class="data-panel">
            <div class="panel-header">
                <div>
                    <h2>Runtime connection</h2>
                    <p>Seeded instance endpoint and repository source.</p>
                </div>
            </div>
            <dl class="detail-list">
                <div>
                    <dt>Repository URL</dt>
                    <dd><a class="text-link" href="@Repository.WebUrl">@Repository.WebUrl</a></dd>
                </div>
                <div>
                    <dt>Instance URL</dt>
                    <dd>@(Repository.InstanceBaseUrl ?? "No instance registered")</dd>
                </div>
                <div>
                    <dt>Lifecycle</dt>
                    <dd>@DisplayLifecycle(Repository.LifecycleStatus)</dd>
                </div>
            </dl>
        </section>
    }
</section>

@code {
    [Parameter]
    public Guid RepositoryId { get; set; }

    private RepositoryOverview? Repository { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        Repository = await Queries.GetRepositoryAsync(new RepositoryId(RepositoryId));
    }

    private static string DisplayHealth(InstanceHealthStatus? status) =>
        status?.ToString() ?? "No instance";

    private static string DisplayLifecycle(InstanceLifecycleStatus? status) =>
        status?.ToString() ?? "None";

    private static string DisplayMode(ExecutionMode? mode) =>
        mode?.ToString() ?? "None";

    private static string FormatLastSeen(DateTimeOffset? lastSeenAtUtc) =>
        lastSeenAtUtc?.ToString("yyyy-MM-dd HH:mm 'UTC'", System.Globalization.CultureInfo.InvariantCulture) ?? "Never";

    private static string HealthStatusClass(InstanceHealthStatus? status) =>
        status switch
        {
            InstanceHealthStatus.Healthy => "status-badge status-healthy",
            InstanceHealthStatus.Warning => "status-badge status-warning",
            InstanceHealthStatus.Critical or InstanceHealthStatus.Offline => "status-badge status-critical",
            _ => "status-badge",
        };
}
