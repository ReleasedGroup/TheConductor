@page "/"
@using System.Globalization
@using System.Text.Json
@using Conductor.Core.Application.Dashboard
@using Conductor.Core.Domain
@inject IDashboardProjectionStore DashboardProjectionStore
@inject IActiveRepositoryDashboardQuery ActiveRepositoryDashboardQuery

<PageTitle>Conductor Dashboard</PageTitle>

<section class="dashboard">
    <header class="dashboard-header">
        <div>
            <p class="eyebrow">Fleet overview</p>
            <h1>Conductor Dashboard</h1>
            <p class="dashboard-summary">Repository health, workload, pull requests, failures, and recent orchestration activity.</p>
        </div>
        <div class="dashboard-meta">
            <StatusBadge Text="Sprint 2 dashboard" Tone="@StatusBadgeTone.Info" />
            @if (projection is not null)
            {
                <span class="projection-stamp">Projection @projection.CapturedAtUtc.ToLocalTime().ToString("MMM d, yyyy HH:mm", CultureInfo.InvariantCulture)</span>
            }
        </div>
    </header>

    @if (loadError is not null)
    {
        <ErrorState
            Title="Dashboard metrics could not be loaded."
            Message="Check the dashboard projection source and try again."
            Detail="@loadError" />
    }
    else if (projection is null)
    {
        <LoadingState
            Title="Loading dashboard metrics"
            Message="Fetching persisted dashboard projection data." />
    }
    else if (projection.Metrics.Count == 0)
    {
        <EmptyState
            Title="No dashboard metrics are available yet."
            Message="Metrics will appear after dashboard projection data is collected." />
    }
    else
    {
        <section class="metric-grid" aria-label="Dashboard metrics">
            @foreach (DashboardMetric metric in projection.Metrics)
            {
                <MetricTile Metric="metric" />
            }
        </section>
    }

    <section class="dashboard-body">
        <div class="dashboard-stack">
            <HealthHeatmap Buckets="HealthBuckets" />
            <InstanceRuntimePanel Items="InstanceRuntimes" />

            <section class="active-repositories-panel" aria-labelledby="active-repositories-heading">
                <div class="panel-heading">
                    <div>
                        <h2 id="active-repositories-heading">Active Repositories</h2>
                        <p>Live repository projection from Conductor persistence.</p>
                    </div>
                    <span>@RepositoryCountLabel</span>
                </div>

                @if (isLoadingRepositories)
                {
                    <LoadingState
                        Title="Loading repositories"
                        Message="Reading the persisted dashboard projection."
                        Class="table-state" />
                }
                else if (repositoryLoadFailed)
                {
                    <ErrorState
                        Title="Repository data is unavailable"
                        Message="The dashboard shell is running, but the repository projection could not be loaded."
                        Class="table-state" />
                }
                else if (ActiveRepositoryRows.Count == 0)
                {
                    <EmptyState
                        Title="No active repositories yet"
                        Message="Imported repositories will appear here after they are persisted."
                        Class="table-state" />
                }
                else
                {
                    <div class="repository-table-wrap">
                        <table class="repository-table">
                            <thead>
                                <tr>
                                    <th scope="col">Project</th>
                                    <th scope="col">Repository</th>
                                    <th scope="col">Health</th>
                                    <th scope="col">Active Issues</th>
                                    <th scope="col">Running Agents</th>
                                    <th scope="col">Failed Runs</th>
                                    <th scope="col">PRs Open</th>
                                    <th scope="col">Last Activity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (ActiveRepositoryDashboardRow repository in ActiveRepositoryRows)
                                {
                                    <tr>
                                        <td>@repository.ProjectName</td>
                                        <td>
                                            <span class="repository-name">@RepositoryName(repository.RepositoryFullName)</span>
                                            <small>@repository.RepositoryFullName</small>
                                        </td>
                                        <td>
                                            <StatusBadge Text="@HealthLabel(repository.Health)" Tone="@HealthTone(repository.Health)" />
                                        </td>
                                        <td class="numeric-cell">@repository.ActiveIssueCount</td>
                                        <td class="numeric-cell">@repository.RunningAgentCount</td>
                                        <td class="@FailedRunClass(repository.FailedRunCount)">@repository.FailedRunCount</td>
                                        <td class="numeric-cell">@repository.OpenPullRequestCount</td>
                                        <td>@FormatLastActivity(repository.LastActivityAtUtc)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section class="startup-panel" aria-label="Startup verification">
                <SuccessState
                    Title="Startup verification"
                    Message="The local host can be checked from the dashboard route and the built-in health probes." />
                <dl>
                    @foreach ((string Label, string Route, string State) check in StartupChecks)
                    {
                        <div>
                            <dt>@check.Label</dt>
                            <dd>
                                <code>@check.Route</code>
                                <span>@check.State</span>
                            </dd>
                        </div>
                    }
                </dl>
            </section>
        </div>

        <aside class="dashboard-rail" aria-label="Dashboard attention">
            <NeedsAttentionPanel Items="AttentionItems" />
            <LiveActivityStream Events="ActivityEvents" ReferenceTimeUtc="ReferenceTimeUtc" />
        </aside>
    </section>
</section>

@code {
    private DashboardProjection? projection;
    private string? loadError;
    private ActiveRepositoryDashboard activeRepositoryDashboard = new([]);
    private bool isLoadingRepositories = true;
    private bool repositoryLoadFailed;

    private IReadOnlyList<DashboardAttentionItem> AttentionItems =>
        projection?.AttentionItems ?? Array.Empty<DashboardAttentionItem>();

    private IReadOnlyList<ActiveRepositoryDashboardRow> ActiveRepositoryRows => activeRepositoryDashboard.Rows;

    private string RepositoryCountLabel =>
        ActiveRepositoryRows.Count == 1
            ? "1 repository"
            : $"{ActiveRepositoryRows.Count.ToString(CultureInfo.InvariantCulture)} repositories";

    private IReadOnlyList<DashboardInstanceRuntime> InstanceRuntimes =>
        projection?.InstanceRuntimes ?? Array.Empty<DashboardInstanceRuntime>();

    private static readonly HealthHeatmapBucket[] HealthBuckets =
    [
        new("Conductor", "08:00", HealthHeatmapStatus.Healthy, 99, "All orchestration checks completed."),
        new("Conductor", "10:00", HealthHeatmapStatus.Healthy, 98, "Workers and health probes are responsive."),
        new("Conductor", "12:00", HealthHeatmapStatus.Warning, 82, "One repository sync ran behind schedule."),
        new("Conductor", "14:00", HealthHeatmapStatus.Healthy, 97, "Backlog recovered after retry."),
        new("Conductor", "16:00", HealthHeatmapStatus.Healthy, 99, "No active orchestration alerts."),
        new("Conductor", "18:00", HealthHeatmapStatus.Healthy, 100, "All repositories are within policy."),
        new("Symphony", "08:00", HealthHeatmapStatus.Healthy, 95, "Runtime checks passed."),
        new("Symphony", "10:00", HealthHeatmapStatus.Warning, 76, "Release polling reported elevated latency."),
        new("Symphony", "12:00", HealthHeatmapStatus.Warning, 73, "Two issue sync jobs are queued."),
        new("Symphony", "14:00", HealthHeatmapStatus.Critical, 41, "Workflow dispatch failed repeatedly."),
        new("Symphony", "16:00", HealthHeatmapStatus.Warning, 78, "Dispatch recovered with retry backlog."),
        new("Symphony", "18:00", HealthHeatmapStatus.Healthy, 93, "Queue returned to normal."),
        new("Release Portal", "08:00", HealthHeatmapStatus.Offline, 0, "No agent heartbeat received."),
        new("Release Portal", "10:00", HealthHeatmapStatus.Critical, 38, "Repository credentials need rotation."),
        new("Release Portal", "12:00", HealthHeatmapStatus.Warning, 69, "Credential rotation started."),
        new("Release Portal", "14:00", HealthHeatmapStatus.Warning, 72, "Pending PR checks are draining."),
        new("Release Portal", "16:00", HealthHeatmapStatus.Healthy, 91, "Credential rotation completed."),
        new("Release Portal", "18:00", HealthHeatmapStatus.Healthy, 94, "Orchestration checks are current."),
        new("Operations Docs", "08:00", HealthHeatmapStatus.Healthy, 96, "Documentation validation passed."),
        new("Operations Docs", "10:00", HealthHeatmapStatus.Healthy, 96, "No blocked documentation runs."),
        new("Operations Docs", "12:00", HealthHeatmapStatus.Healthy, 97, "Review queue is clear."),
        new("Operations Docs", "14:00", HealthHeatmapStatus.Healthy, 96, "Scheduled checks completed."),
        new("Operations Docs", "16:00", HealthHeatmapStatus.Warning, 80, "One stale branch requires attention."),
        new("Operations Docs", "18:00", HealthHeatmapStatus.Healthy, 95, "Stale branch warning cleared."),
    ];

    private static readonly DateTimeOffset ReferenceTimeUtc = new(2026, 4, 29, 18, 20, 0, TimeSpan.Zero);

    private static readonly LiveActivityEvent[] ActivityEvents =
    [
        new(
            ReferenceTimeUtc.AddMinutes(-4),
            EventSeverity.Information,
            "Workspace prepared",
            "acme-portal",
            128,
            "Workspace prepared for the next orchestration run."),
        new(
            ReferenceTimeUtc.AddMinutes(-8),
            EventSeverity.Error,
            "Continuation started",
            "billing-api",
            77,
            "Tests failed and a continuation run started."),
        new(
            ReferenceTimeUtc.AddMinutes(-12),
            EventSeverity.Warning,
            "Instance offline",
            "client-mobile",
            null,
            "Symphony instance health moved to offline."),
        new(
            ReferenceTimeUtc.AddMinutes(-15),
            EventSeverity.Information,
            "Run completed",
            "data-pipeline",
            102,
            "Run completed successfully."),
    ];

    private static readonly (string Label, string Route, string State)[] StartupChecks =
    [
        ("Dashboard route", "/", "Metric tiles served"),
        ("Live health", "/health/live", "Probe available"),
        ("Ready health", "/health/ready", "Probe available"),
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardProjectionAsync();
        await LoadActiveRepositoriesAsync();
    }

    private async Task LoadDashboardProjectionAsync()
    {
        try
        {
            projection = await DashboardProjectionStore.GetCurrentAsync();
        }
        catch (Exception ex) when (ex is IOException or JsonException or UnauthorizedAccessException)
        {
            loadError = ex.Message;
        }
    }

    private async Task LoadActiveRepositoriesAsync()
    {
        try
        {
            activeRepositoryDashboard = await ActiveRepositoryDashboardQuery.LoadAsync();
        }
        catch (Exception)
        {
            repositoryLoadFailed = true;
            activeRepositoryDashboard = new ActiveRepositoryDashboard([]);
        }
        finally
        {
            isLoadingRepositories = false;
        }
    }

    private static string RepositoryName(string fullName)
    {
        int slashIndex = fullName.LastIndexOf('/');

        return slashIndex >= 0 && slashIndex < fullName.Length - 1
            ? fullName[(slashIndex + 1)..]
            : fullName;
    }

    private static string HealthLabel(DashboardRepositoryHealth health) =>
        health switch
        {
            DashboardRepositoryHealth.Healthy => "Healthy",
            DashboardRepositoryHealth.Warning => "Warning",
            DashboardRepositoryHealth.Critical => "Critical",
            DashboardRepositoryHealth.Offline => "Offline",
            _ => "Unknown",
        };

    private static StatusBadgeTone HealthTone(DashboardRepositoryHealth health) =>
        health switch
        {
            DashboardRepositoryHealth.Healthy => StatusBadgeTone.Success,
            DashboardRepositoryHealth.Warning => StatusBadgeTone.Warning,
            DashboardRepositoryHealth.Critical => StatusBadgeTone.Critical,
            DashboardRepositoryHealth.Offline => StatusBadgeTone.Neutral,
            _ => StatusBadgeTone.Neutral,
        };

    private static string FailedRunClass(int failedRunCount) =>
        failedRunCount > 0 ? "numeric-cell numeric-cell-critical" : "numeric-cell";

    private static string FormatLastActivity(DateTimeOffset? lastActivityAtUtc)
    {
        if (lastActivityAtUtc is null)
        {
            return "No activity";
        }

        TimeSpan elapsed = DateTimeOffset.UtcNow - lastActivityAtUtc.Value;

        if (elapsed <= TimeSpan.FromMinutes(1))
        {
            return "Now";
        }

        if (elapsed < TimeSpan.FromHours(1))
        {
            return $"{Math.Floor(elapsed.TotalMinutes).ToString(CultureInfo.InvariantCulture)}m ago";
        }

        if (elapsed < TimeSpan.FromDays(1))
        {
            return $"{Math.Floor(elapsed.TotalHours).ToString(CultureInfo.InvariantCulture)}h ago";
        }

        return lastActivityAtUtc.Value.UtcDateTime.ToString("MMM d, yyyy", CultureInfo.InvariantCulture);
    }
}
