@page "/"

<PageTitle>Conductor Dashboard</PageTitle>

<section class="dashboard-heading">
    <div>
        <p class="eyebrow">Sprint 0 foundation</p>
        <h1>Conductor dashboard</h1>
    </div>
    <div class="status-summary">
        <span class="status-dot healthy" aria-hidden="true"></span>
        Host online
    </div>
</section>

<section class="metric-grid" aria-label="Portfolio metrics">
    @foreach (var metric in Metrics)
    {
        <article class="metric-panel">
            <span class="metric-label">@metric.Label</span>
            <strong>@metric.Value</strong>
            <span class="metric-detail">@metric.Detail</span>
        </article>
    }
</section>

<section class="dashboard-grid">
    <article class="panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Repository fleet</p>
                <h2>Active repositories</h2>
            </div>
            <span class="panel-meta">Demo data</span>
        </div>

        <div class="repository-table" role="table" aria-label="Active repositories">
            <div class="table-row table-head" role="row">
                <span role="columnheader">Project</span>
                <span role="columnheader">Repository</span>
                <span role="columnheader">Health</span>
                <span role="columnheader">Running</span>
                <span role="columnheader">Updated</span>
            </div>
            @foreach (var repository in Repositories)
            {
                <div class="table-row" role="row">
                    <span role="cell">@repository.Project</span>
                    <span role="cell">@repository.Name</span>
                    <span role="cell">
                        <span class="health-badge @repository.HealthClass">@repository.Health</span>
                    </span>
                    <span role="cell">@repository.RunningAgents</span>
                    <span role="cell">@repository.Updated</span>
                </div>
            }
        </div>
    </article>

    <aside class="panel attention-panel" aria-label="Needs attention">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Operations</p>
                <h2>Needs attention</h2>
            </div>
        </div>

        <ol class="attention-list">
            @foreach (var item in AttentionItems)
            {
                <li>
                    <strong>@item.Title</strong>
                    <span>@item.Detail</span>
                </li>
            }
        </ol>
    </aside>
</section>

@code {
    private static readonly Metric[] Metrics =
    [
        new("Managed repositories", "0", "Registry pending"),
        new("Symphony instances", "0", "No active runners"),
        new("Active agents", "0", "Idle"),
        new("Blocked issues", "0", "No alerts")
    ];

    private static readonly RepositoryRow[] Repositories =
    [
        new("Foundation", "conductor-host", "Healthy", "healthy", "0", "Just now"),
        new("Platform", "persistence", "Pending", "warning", "0", "Not provisioned"),
        new("Operations", "runners", "Pending", "warning", "0", "Not provisioned")
    ];

    private static readonly AttentionItem[] AttentionItems =
    [
        new("No managed repositories", "Repository registry is empty."),
        new("No Symphony instances", "Fleet runtime is idle."),
        new("CI baseline", "Automation workflow is not configured.")
    ];

    private sealed record Metric(string Label, string Value, string Detail);

    private sealed record RepositoryRow(
        string Project,
        string Name,
        string Health,
        string HealthClass,
        string RunningAgents,
        string Updated);

    private sealed record AttentionItem(string Title, string Detail);
}
