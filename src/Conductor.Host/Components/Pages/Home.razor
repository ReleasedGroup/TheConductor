        new("crm-sync", "24h", HealthHeatmapStatus.Healthy, 96, "Documentation validation passed."),
        new("crm-sync", "18h", HealthHeatmapStatus.Healthy, 96, "No blocked documentation runs."),
        new("crm-sync", "12h", HealthHeatmapStatus.Healthy, 97, "Review queue is clear."),
        new("crm-sync", "6h", HealthHeatmapStatus.Warning, 80, "One stale branch requires attention."),
        new("crm-sync", "Now", HealthHeatmapStatus.Healthy, 95, "Stale branch warning cleared."),
        new("data-pipeline", "24h", HealthHeatmapStatus.Healthy, 92, "Collectors completed normally."),
        new("data-pipeline", "18h", HealthHeatmapStatus.Warning, 71, "Queue depth increased."),
        new("data-pipeline", "12h", HealthHeatmapStatus.Healthy, 91, "Queue depth recovered."),
        new("data-pipeline", "6h", HealthHeatmapStatus.Critical, 35, "High failure rate detected."),
        new("data-pipeline", "Now", HealthHeatmapStatus.Critical, 40, "Failure rate remains elevated.")
    ];

    private static readonly WorkloadProjection Workload = new()
    {
        TotalActiveIssues = 138,
        Slices =
        [
            new() { Label = "In Progress", Count = 78, Percentage = "57%", Color = "#3b82f6" },
            new() { Label = "Queued", Count = 22, Percentage = "16%", Color = "#2563eb" },
            new() { Label = "Retrying", Count = 11, Percentage = "8%", Color = "#facc15" },
            new() { Label = "Blocked", Count = 7, Percentage = "5%", Color = "#ef4444" },
            new() { Label = "Done", Count = 20, Percentage = "14%", Color = "#22c55e" }
        ]
    };

    private static readonly RepositoryRow[] Repositories =
    [
        new() { Project = "ACME Portal", Repository = "acme-portal", Health = "Healthy", ActiveIssues = 9, RunningAgents = 3, FailedRuns = 0, OpenPullRequests = 2, LastActivity = "4m ago", Sparkline = "___/\\_/\\_" },
        new() { Project = "Billing Engine", Repository = "billing-api", Health = "Warning", ActiveIssues = 14, RunningAgents = 5, FailedRuns = 2, OpenPullRequests = 1, LastActivity = "1m ago", Sparkline = "_/\\/\\_/_" },
        new() { Project = "Mobile App", Repository = "client-mobile", Health = "Offline", ActiveIssues = 0, RunningAgents = 0, FailedRuns = 0, OpenPullRequests = 0, LastActivity = "2h ago", Sparkline = "________" },
        new() { Project = "CRM Sync", Repository = "crm-sync", Health = "Healthy", ActiveIssues = 7, RunningAgents = 2, FailedRuns = 0, OpenPullRequests = 1, LastActivity = "6m ago", Sparkline = "__/\\_/\\_" },
        new() { Project = "Data Pipeline", Repository = "data-pipeline", Health = "Warning", ActiveIssues = 11, RunningAgents = 3, FailedRuns = 3, OpenPullRequests = 2, LastActivity = "3m ago", Sparkline = "_/\\/\\_/\\/" },
        new() { Project = "Internal Tools", Repository = "internal-tools", Health = "Healthy", ActiveIssues = 4, RunningAgents = 1, FailedRuns = 0, OpenPullRequests = 0, LastActivity = "10m ago", Sparkline = "__/\\____" },
        new() { Project = "Marketing Site", Repository = "marketing-site", Health = "Healthy", ActiveIssues = 3, RunningAgents = 1, FailedRuns = 0, OpenPullRequests = 1, LastActivity = "12m ago", Sparkline = "_/\\__/\\_" }
    ];

    private static readonly LiveActivityEvent[] ActivityEvents =
    [
        new(
            ReferenceTimeUtc.AddMinutes(-2),
            EventSeverity.Information,
            "Pull request opened",
            "crm-sync",
            44,
            "Pull request opened."),
        new(
            ReferenceTimeUtc.AddMinutes(-4),
            EventSeverity.Information,
            "Workspace prepared",
            "acme-portal",
            128,
            "Workspace prepared for the next orchestration run."),
        new(
            ReferenceTimeUtc.AddMinutes(-8),
            EventSeverity.Error,
            "Continuation started",
            "billing-api",
            77,
            "Tests failed and a continuation run started."),
        new(
            ReferenceTimeUtc.AddMinutes(-12),
            EventSeverity.Warning,
            "Instance offline",
            "client-mobile",
            null,
            "Symphony instance health moved to offline."),
        new(
            ReferenceTimeUtc.AddMinutes(-15),
            EventSeverity.Information,
            "Run completed",
            "data-pipeline",
            102,
            "Run completed successfully.")
    ];

    private static readonly QuickAction[] QuickActions =
    [
        new() { Title = "Import Repository", Description = "Add a GitHub repository to orchestration", Href = "/repositories", Icon = "IR" },
        new() { Title = "New Workflow Profile", Description = "Create a workflow profile from a template", Href = "/policies", Icon = "WF" },
        new() { Title = "Generate Report", Description = "Create a delivery or executive report", Href = "/reports", Icon = "GR" },
        new() { Title = "Global Policies", Description = "View and manage orchestration policies", Href = "/policies", Icon = "GP" }
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardProjectionAsync();
        await LoadActiveRepositoriesAsync();
    }

    private async Task LoadDashboardProjectionAsync()
    {
        try
        {
            projection = await DashboardProjectionStore.GetCurrentAsync();
        }
        catch (Exception ex) when (ex is IOException or JsonException or UnauthorizedAccessException or InvalidOperationException)
        {
            loadError = ex.Message;
        }
    }

    private async Task LoadActiveRepositoriesAsync()
    {
        try
        {
            activeRepositoryDashboard = await ActiveRepositoryDashboardQuery.LoadAsync();
        }
        catch (Exception)
        {
            repositoryLoadFailed = true;
            activeRepositoryDashboard = new ActiveRepositoryDashboard([]);
        }
        finally
        {
            isLoadingRepositories = false;
        }
    }

    private static string RepositoryName(string fullName)
    {
        int slashIndex = fullName.LastIndexOf('/');

        return slashIndex >= 0 && slashIndex < fullName.Length - 1
            ? fullName[(slashIndex + 1)..]
            : fullName;
    }

    private static string HealthLabel(DashboardRepositoryHealth health) =>
        health switch
        {
            DashboardRepositoryHealth.Healthy => "Healthy",
            DashboardRepositoryHealth.Warning => "Warning",
            DashboardRepositoryHealth.Critical => "Critical",
            DashboardRepositoryHealth.Offline => "Offline",
            _ => "Unknown",
        };

    private static StatusBadgeTone HealthTone(DashboardRepositoryHealth health) =>
        health switch
        {
            DashboardRepositoryHealth.Healthy => StatusBadgeTone.Success,
            DashboardRepositoryHealth.Warning => StatusBadgeTone.Warning,
            DashboardRepositoryHealth.Critical => StatusBadgeTone.Critical,
            DashboardRepositoryHealth.Offline => StatusBadgeTone.Neutral,
            _ => StatusBadgeTone.Neutral,
        };

    private static string FailedRunClass(int failedRunCount) =>
        failedRunCount > 0 ? "numeric-cell numeric-cell-critical" : "numeric-cell";

    private static string FormatLastActivity(DateTimeOffset? lastActivityAtUtc)
    {
        if (lastActivityAtUtc is null)
        {
            return "No activity";
        }

        TimeSpan elapsed = DateTimeOffset.UtcNow - lastActivityAtUtc.Value;

        if (elapsed <= TimeSpan.FromMinutes(1))
        {
            return "Now";
        }

        if (elapsed < TimeSpan.FromHours(1))
        {
            return $"{Math.Floor(elapsed.TotalMinutes).ToString(CultureInfo.InvariantCulture)}m ago";
        }

        if (elapsed < TimeSpan.FromDays(1))
        {
            return $"{Math.Floor(elapsed.TotalHours).ToString(CultureInfo.InvariantCulture)}h ago";
        }

        return lastActivityAtUtc.Value.UtcDateTime.ToString("MMM d, yyyy", CultureInfo.InvariantCulture);
    }
}
