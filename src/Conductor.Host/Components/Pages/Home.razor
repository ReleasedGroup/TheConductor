@page "/"
@using System.Text.Json
@using Conductor.Core.Application.Dashboard
@using Conductor.Core.Domain
@inject IDashboardProjectionStore DashboardProjectionStore

<PageTitle>Dashboard | Conductor</PageTitle>

@if (loadError is not null)
{
    <ErrorState
        Class="state-panel"
        Title="Dashboard metrics could not be loaded."
        Message="Check the dashboard projection source and try again."
        Detail="@loadError" />
}
else if (projection is null)
{
    <LoadingState
        Class="state-panel"
        Title="Loading dashboard metrics"
        Message="Fetching persisted dashboard projection data." />
}
else
{
    <section class="dashboard-page" aria-labelledby="dashboard-title">
        <div class="page-heading">
            <div>
                <p class="eyebrow">Fleet overview</p>
                <h1 id="dashboard-title">Dashboard</h1>
                <p>Good morning, Nick. Here is what is happening across your software orchestra.</p>
            </div>
            <div class="scope-controls" aria-label="Dashboard filters">
                <StatusBadge Text="Sprint 2 metrics" Tone="StatusBadgeTone.Info" />
                <span class="projection-stamp">Projection @projection.CapturedAtUtc.ToLocalTime().ToString("MMM d, yyyy HH:mm")</span>
            </div>
        </div>

        @if (projection.Metrics.Count == 0)
        {
            <EmptyState
                Class="dashboard-state"
                Title="No dashboard metrics are available yet."
                Message="Metrics will appear after dashboard projection data is collected." />
        }
        else
        {
            <section class="metric-grid" aria-label="Dashboard metrics">
                @foreach (DashboardMetric metric in projection.Metrics)
                {
                    <MetricTile Metric="metric" />
                }
            </section>
        }

        <div class="dashboard-grid">
            <HealthHeatmap
                Title="Repository orchestration health"
                Description="Repository health over the latest orchestration windows."
                Buckets="HealthBuckets" />
            <WorkloadDonut Workload="Workload" />
            <InstanceRuntimePanel Items="InstanceRuntimes" />
            <NeedsAttentionPanel Items="AttentionItems" />
            <RepositoryTable Repositories="Repositories" />
            <QuickActions Actions="QuickActions" />
            <LiveActivityStream Events="ActivityEvents" ReferenceTimeUtc="ReferenceTimeUtc" />
        </div>
    </section>
}

