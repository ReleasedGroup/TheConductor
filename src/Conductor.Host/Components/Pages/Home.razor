@page "/"
@using System.Globalization
@using System.Text.Json
@using Conductor.Core.Application.Dashboard
@using Conductor.Core.Domain
@inject IDashboardProjectionStore DashboardProjectionStore
@inject IActiveRepositoryDashboardQuery ActiveRepositoryDashboardQuery

<PageTitle>Dashboard | Conductor</PageTitle>

<section class="dashboard">
    <header class="dashboard-header">
        <div>
            <p class="eyebrow">Fleet overview</p>
            <h1>Conductor Dashboard</h1>
            <p class="dashboard-summary">Repository health, workload, pull requests, failures, and recent orchestration activity.</p>
        </div>
        <div class="dashboard-meta">
            <StatusBadge Text="Sprint 2 dashboard" Tone="@StatusBadgeTone.Info" />
            @if (projection is not null)
            {
                <span class="projection-stamp">Projection @projection.CapturedAtUtc.ToLocalTime().ToString("MMM d, yyyy HH:mm", CultureInfo.InvariantCulture)</span>
            }
        </div>
    </header>

    @if (loadError is not null)
    {
        <ErrorState
            Class="dashboard-state"
            Title="Dashboard metrics could not be loaded."
            Message="Check the dashboard projection source and try again."
            Detail="@loadError" />
    }
    else if (projection is null)
    {
        <LoadingState
            Class="dashboard-state"
            Title="Loading dashboard metrics"
            Message="Fetching persisted dashboard projection data." />
    }
    else if (projection.Metrics.Count == 0)
    {
        <EmptyState
            Class="dashboard-state"
            Title="No dashboard metrics are available yet."
            Message="Metrics will appear after dashboard projection data is collected." />
    }
    else
    {
        <section class="metric-grid" aria-label="Dashboard metrics">
            @foreach (DashboardMetric metric in projection.Metrics)
            {
                <MetricTile Metric="metric" />
            }
        </section>
    }

    <section class="dashboard-body">
        <div class="dashboard-grid">
            <HealthHeatmap
                Title="Repository orchestration health"
                Description="Repository health over the latest orchestration windows."
                Buckets="HealthBuckets" />
            <WorkloadDonut Workload="Workload" />
            <InstanceRuntimePanel Items="InstanceRuntimes" />
            <NeedsAttentionPanel Items="AttentionItems" />

            <section class="active-repositories-panel" aria-labelledby="active-repositories-heading">
                <div class="panel-heading">
                    <div>
                        <h2 id="active-repositories-heading">Active Repositories</h2>
                        <p>Live repository projection from Conductor persistence.</p>
                    </div>
                    <span>@RepositoryCountLabel</span>
                </div>

                @if (isLoadingRepositories)
                {
                    <LoadingState
                        Title="Loading repositories"
                        Message="Reading the persisted dashboard projection."
                        Class="table-state" />
                }
                else if (repositoryLoadFailed)
                {
                    <ErrorState
                        Title="Repository data is unavailable"
                        Message="The dashboard shell is running, but the repository projection could not be loaded."
                        Class="table-state" />
                }
                else if (ActiveRepositoryRows.Count == 0)
                {
                    <EmptyState
                        Title="No active repositories yet"
                        Message="Imported repositories will appear here after they are persisted."
                        Class="table-state" />
                }
                else
                {
                    <div class="repository-table-wrap">
                        <table class="repository-table">
                            <thead>
                                <tr>
                                    <th scope="col">Project</th>
                                    <th scope="col">Repository</th>
                                    <th scope="col">Health</th>
                                    <th scope="col">Active Issues</th>
                                    <th scope="col">Running Agents</th>
                                    <th scope="col">Failed Runs</th>
                                    <th scope="col">PRs Open</th>
                                    <th scope="col">Last Activity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (ActiveRepositoryDashboardRow repository in ActiveRepositoryRows)
                                {
                                    <tr>
                                        <td>@repository.ProjectName</td>
                                        <td>
                                            <span class="repository-name">@RepositoryName(repository.RepositoryFullName)</span>
                                            <small>@repository.RepositoryFullName</small>
                                        </td>
                                        <td>
                                            <StatusBadge Text="@HealthLabel(repository.Health)" Tone="@HealthTone(repository.Health)" />
                                        </td>
                                        <td class="numeric-cell">@repository.ActiveIssueCount</td>
                                        <td class="numeric-cell">@repository.RunningAgentCount</td>
                                        <td class="@FailedRunClass(repository.FailedRunCount)">@repository.FailedRunCount</td>
                                        <td class="numeric-cell">@repository.OpenPullRequestCount</td>
                                        <td>@FormatLastActivity(repository.LastActivityAtUtc)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <RepositoryTable Repositories="Repositories" />
            <QuickActions Actions="QuickActions" />
            <LiveActivityStream Events="ActivityEvents" ReferenceTimeUtc="ReferenceTimeUtc" />

            <section class="startup-panel panel" aria-label="Startup verification">
                <SuccessState
                    Title="Startup verification"
                    Message="The local host can be checked from the dashboard route and the built-in health probes." />
                <dl>
                    @foreach ((string Label, string Route, string State) check in StartupChecks)
                    {
                        <div>
                            <dt>@check.Label</dt>
                            <dd>
                                <code>@check.Route</code>
                                <span>@check.State</span>
                            </dd>
                        </div>
                    }
                </dl>
            </section>
        </div>
    </section>
</section>

@code {
    private static readonly DateTimeOffset ReferenceTimeUtc = new(2026, 4, 29, 18, 20, 0, TimeSpan.Zero);

    private DashboardProjection? projection;
    private string? loadError;
    private ActiveRepositoryDashboard activeRepositoryDashboard = new([]);
    private bool isLoadingRepositories = true;
    private bool repositoryLoadFailed;

    private IReadOnlyList<DashboardAttentionItem> AttentionItems =>
        projection?.AttentionItems ?? Array.Empty<DashboardAttentionItem>();

    private IReadOnlyList<ActiveRepositoryDashboardRow> ActiveRepositoryRows => activeRepositoryDashboard.Rows;

    private string RepositoryCountLabel =>
        ActiveRepositoryRows.Count == 1
            ? "1 repository"
            : $"{ActiveRepositoryRows.Count.ToString(CultureInfo.InvariantCulture)} repositories";

    private IReadOnlyList<DashboardInstanceRuntime> InstanceRuntimes =>
        projection?.InstanceRuntimes ?? Array.Empty<DashboardInstanceRuntime>();

    private static readonly (string Label, string Route, string State)[] StartupChecks =
    [
