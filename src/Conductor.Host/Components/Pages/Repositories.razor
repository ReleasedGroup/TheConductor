@page "/repositories"
@using Conductor.Core.Application.Queries
@using Conductor.Core.Domain
@inject IRepositoryListQueryService RepositoryQueries

<PageTitle>Repositories - Conductor</PageTitle>

<section class="dashboard">
    <header class="dashboard-header">
        <div>
            <p class="eyebrow">Repository registry</p>
            <h1>Repositories</h1>
            <p class="dashboard-summary">Development repositories loaded from the SQLite projection store.</p>
        </div>
        <span class="status-pill">Seeded data</span>
    </header>

    @if (RepositoryRows is null)
    {
        <section class="empty-state">
            <p>Loading repositories...</p>
        </section>
    }
    else if (RepositoryRows.Count == 0)
    {
        <section class="empty-state">
            <p>No repositories are registered.</p>
        </section>
    }
    else
    {
        <section class="data-panel">
            <div class="panel-header">
                <div>
                    <h2>Imported repositories</h2>
                    <p>Seeded records for repository list and command-centre flows.</p>
                </div>
            </div>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Repository</th>
                            <th>Project</th>
                            <th>Branch</th>
                            <th>Instances</th>
                            <th>Health</th>
                            <th>Last check</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (RepositoryListItemProjection repository in RepositoryRows)
                        {
                            <tr>
                                <td>
                                    <a href="@RepositoryHref(repository)">@repository.FullName</a>
                                </td>
                                <td>@(repository.ProjectName ?? "Unassigned")</td>
                                <td>@repository.DefaultBranch</td>
                                <td>@repository.RunningInstanceCount / @repository.InstanceCount running</td>
                                <td><span class="@HealthStatusClass(repository.WorstHealthStatus)">@repository.WorstHealthStatus</span></td>
                                <td>@FormatLastSeen(repository.LastHealthCheckAtUtc)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</section>

@code {
    private IReadOnlyList<RepositoryListItemProjection>? RepositoryRows { get; set; }

    protected override async Task OnInitializedAsync()
    {
        RepositoryRows = await RepositoryQueries.ListRepositoriesAsync(new RepositoryListQuery());
    }

    private static string RepositoryHref(RepositoryListItemProjection repository) =>
        $"/repositories/{repository.Id.Value:D}";

    private static string FormatLastSeen(DateTimeOffset? lastSeenAtUtc) =>
        lastSeenAtUtc?.ToString("yyyy-MM-dd HH:mm 'UTC'", System.Globalization.CultureInfo.InvariantCulture) ?? "Never";

    private static string HealthStatusClass(InstanceHealthStatus status) =>
        status switch
        {
            InstanceHealthStatus.Healthy => "status-badge status-healthy",
            InstanceHealthStatus.Warning => "status-badge status-warning",
            InstanceHealthStatus.Critical or InstanceHealthStatus.Offline => "status-badge status-critical",
            _ => "status-badge",
        };
}
